              "schema": {
                "$ref": "#/components/schemas/CourierCreateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CourierCreateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CourierCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
