    "schemas": {
      "CourierCreateDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "vehicleType": {
            "type": "string",
            "nullable": true
          },
          "lastLatitude": {
            "type": "number",
            "format": "double"
          },
          "lastLongitude": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "OrderCreateDto": {
        "type": "object",
        "properties": {
          "customerName": {
            "type": "string",
            "nullable": true
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    }
  }
