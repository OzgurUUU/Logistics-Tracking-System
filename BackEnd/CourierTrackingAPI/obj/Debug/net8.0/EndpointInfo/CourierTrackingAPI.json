{
  "openapi": "3.0.1",
  "info": {
    "title": "CourierTrackingAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Courier": {
      "get": {
        "tags": [
          "Courier"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Courier"
